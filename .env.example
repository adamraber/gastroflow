# ─── Auth.js ──────────────────────────────────────────────────────────────────
AUTH_SECRET=generate-with-openssl-rand-base64-32
AUTH_GOOGLE_ID=your-google-oauth-client-id
AUTH_GOOGLE_SECRET=your-google-oauth-client-secret

# ─── Database (Supabase) ───────────────────────────────────────────────────────
# Transaction pooler (for Prisma queries)
DATABASE_URL="postgresql://postgres.[project-ref]:[password]@aws-0-sa-east-1.pooler.supabase.com:6543/postgres?pgbouncer=true"
# Direct connection (for Prisma migrations)
DIRECT_URL="postgresql://postgres.[project-ref]:[password]@aws-0-sa-east-1.pooler.supabase.com:5432/postgres"

NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# ─── Google AI (Gemini) ────────────────────────────────────────────────────────
GEMINI_API_KEY=your-gemini-api-key

# ─── Resend (Email) ────────────────────────────────────────────────────────────
RESEND_API_KEY=re_your-resend-api-key
RESEND_FROM_EMAIL=consultas@gastroflow.com.ar

# ─── MercadoPago ──────────────────────────────────────────────────────────────
MERCADOPAGO_ACCESS_TOKEN=APP_USR-your-access-token
NEXT_PUBLIC_MERCADOPAGO_PUBLIC_KEY=APP_USR-your-public-key

# ─── App ───────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
CONSULTATION_PRICE_ARS=10000
